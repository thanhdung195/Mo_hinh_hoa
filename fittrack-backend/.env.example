# Copy this file to .env and edit to match your XAMPP setup.
# The server reads these with process.env.* — no dotenv package required
# if you pass them directly, or install dotenv and import at the top of server.js.

# MySQL / XAMPP
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=fittrack

# Express session secret (change this!)
SESSION_SECRET=super-secret-change-me

# Optional: absolute path to your frontend folder
# FRONTEND_DIR=C:/xampp/htdocs/fittrack-frontend

# Port
PORT=3000
